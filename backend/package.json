    "nanoid": "^3.3.7",
    "ethers": "^6.9.0",
    "prisma": "^5.7.0",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "ts-node-dev": "^2.0.0"
  }
}
